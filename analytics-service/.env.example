# HTTP port the app listens on. Overridden by the hosting platform in production.
PORT=8000

DATABASE_URL=postgresql+asyncpg://analytics:analytics@db:5432/analytics
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ISSUER=auth-service

EVENT_BUS_REDIS_URL=redis://redis:6379/0
EVENT_BUS_ENABLED=true

EXPORT_STORAGE_ROOT=storage/exports
EXPORT_WORKER_POLL_INTERVAL_SECONDS=2.0
EXPORT_MAX_ROWS=50000

OTEL_EXPORTER_OTLP_ENDPOINT=
