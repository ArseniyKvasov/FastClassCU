# HTTP port the app listens on. Overridden by the hosting platform in production.
PORT=8000

DATABASE_URL=postgresql+asyncpg://ai:ai@db:5432/ai_assistant

JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ISSUER=auth-service

INTERNAL_SERVICE_TOKEN=dev-insecure-service-token
CONTENT_SERVICE_BASE_URL=http://localhost:8003
CONTENT_SERVICE_TOKEN=dev-insecure-service-token
AUTH_SERVICE_BASE_URL=http://localhost:8001
SERVICE_CLIENT_ID=ai-assistant-service
SERVICE_CLIENT_SECRET=
EVENT_BUS_REDIS_URL=redis://redis:6379/0
EVENT_BUS_ENABLED=true
RATE_LIMIT_REDIS_URL=redis://redis:6379/0
GENERATION_REQUEST_RATE_LIMIT=20
GENERATION_REQUEST_WINDOW_SECONDS=300
OTEL_EXPORTER_OTLP_ENDPOINT=

WORKER_POLL_INTERVAL_SECONDS=2
WORKER_BATCH_SIZE=4
WORKER_MAX_ATTEMPTS=3

USE_MOCK_PROVIDERS=true
AI_GATEWAY_URL=
AI_GATEWAY_SECRET=

GEMMA_MODEL=gemma-4-27b-it
GEMINI_PDF_MODEL=gemini-2.5-flash
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# Base64-encoded "client_id:client_secret" for GigaChat Basic auth.
GIGACHAT_MODEL=GigaChat-2
GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_API_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=

POLLINATIONS_BASE_URL=https://image.pollinations.ai
POLLINATIONS_API_KEY=
POLLINATIONS_IMAGE_MODEL=gptimage

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_IMAGE_MODEL=openai/gpt-image-2

# If AI_GATEWAY_URL is set, Flux can be routed through:
#   {AI_GATEWAY_URL}/pixazo/flux-1-schnell/v1/getData
FLUX_BASE_URL=
FLUX_API_KEY=
FLUX_GATEWAY_PATH=pixazo/flux-1-schnell/v1/getData

RECENT_LESSONS_LIMIT=6
MAX_CONTEXT_LESSONS=3
MAX_FEEDBACK_ITEMS=20
DEFAULT_LESSON_LANGUAGE=ru
DEFAULT_AUDIO_MIME_TYPE=audio/wav
DEFAULT_IMAGE_MIME_TYPE=image/png
DEFAULT_TTS_VOICE=aoede
DEFAULT_IMAGE_QUALITY=low

GENERATION_TIMEOUT_SECONDS=120
PROVIDER_TIMEOUT_SECONDS=60
