DATABASE_URL=postgresql+asyncpg://assignments:assignments@db:5432/assignments
REDIS_URL=redis://redis:6379/0

JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ISSUER=auth-service
INTERNAL_SERVICE_TOKEN=dev-insecure-service-token
ALLOW_LEGACY_INTERNAL_SERVICE_TOKEN=true
EVENT_BUS_REDIS_URL=redis://redis:6379/0
EVENT_BUS_ENABLED=true
SESSION_START_RATE_LIMIT=20
SESSION_START_WINDOW_SECONDS=300
OTEL_EXPORTER_OTLP_ENDPOINT=

WS_HEARTBEAT_INTERVAL_SECONDS=25
WS_HEARTBEAT_MISSED_LIMIT=3

# How often the expiry sweeper runs, and how many rows it closes per pass.
SWEEPER_INTERVAL_SECONDS=30
SWEEPER_BATCH_SIZE=500
