# Copy this file to .env, then start the full stack from the repository root:
#   cp .env.example .env
#   docker compose up --build -d
#
# For OAuth, PUBLIC_BASE_URL must be the browser-visible frontend URL. With the
# default ports below it is http://localhost:8080. Use your own HTTPS URL when
# deploying behind any reverse proxy or load balancer.

PUBLIC_BASE_URL=http://localhost:8080
# Browser-visible auth-service URL. This must be publicly reachable because the
# browser is redirected here before the frontend BFF exchanges the OAuth code.
AUTH_SERVICE_PUBLIC_BASE_URL=http://localhost:8001

# Optional external PostgreSQL / Redis endpoints.
# docker compose uses the service-specific URLs below, and each one falls back
# to the local shared containers when the override is blank.
POSTGRES_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres
REDIS_URL=redis://localhost:6379/0
EVENT_BUS_REDIS_URL=redis://localhost:6379/0
AUTH_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/auth
CONTENT_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/content
CLASSROOM_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/classroom
ASSIGNMENTS_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/assignments
ANSWERS_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/answers
AI_ASSISTANT_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_assistant
COLLABORATION_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/collaboration
ANALYTICS_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/analytics
AUTH_RATE_LIMIT_REDIS_URL=redis://localhost:6379/1
CLASSROOM_REDIS_URL=redis://localhost:6379/2
CLASSROOM_RATE_LIMIT_REDIS_URL=redis://localhost:6379/2
ASSIGNMENTS_REDIS_URL=redis://localhost:6379/3
ANSWERS_REDIS_URL=redis://localhost:6379/4
AI_ASSISTANT_RATE_LIMIT_REDIS_URL=redis://localhost:6379/5
COLLABORATION_REDIS_URL=redis://localhost:6379/6

# OAuth providers. Leave either provider blank to disable it.
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
VK_CLIENT_ID=
VK_CLIENT_SECRET=

# Generate unique random values before exposing this stack publicly, for example:
#   openssl rand -hex 32
OAUTH_STATE_SECRET=dev-insecure-change-me
ANSWERS_SERVICE_CLIENT_SECRET=dev-insecure-answers-service-secret
AI_ASSISTANT_SERVICE_CLIENT_SECRET=dev-insecure-ai-assistant-service-secret
COLLABORATION_SERVICE_CLIENT_SECRET=dev-insecure-collaboration-service-secret
COLLAB_TOKEN_SECRET=dev-insecure-collaboration-token-secret

# Session cookies. Leave COOKIE_DOMAIN blank for a host-only cookie.
# Set COOKIE_SECURE=true when the browser reaches the frontend over HTTPS.
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Collaboration service accepts browser connections from these origins.
# Set this to the actual browser origin when using a custom domain.
CORS_ORIGINS=http://localhost:8080
# Optional explicit public websocket base URL, without /ws/collab.
PUBLIC_WS_BASE_URL=

# Optional external integrations.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_WS_URL=ws://localhost:7880
LIVEKIT_TOKEN_TTL_SECONDS=3600
WHITEBOARD_JWT_SECRET=dev-insecure-change-me
WHITEBOARD_BASE_URL=http://localhost:9000
WHITEBOARD_SERVICE_API_KEY=

# AI integrations. The default mock providers let the service start without
# any third-party credentials.
USE_MOCK_PROVIDERS=true
AI_GATEWAY_URL=
AI_GATEWAY_SECRET=
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=
POLLINATIONS_API_KEY=
OPENROUTER_API_KEY=
FLUX_BASE_URL=
FLUX_API_KEY=

# Optional OpenTelemetry collector endpoint. Leave blank to disable export.
OTEL_EXPORTER_OTLP_ENDPOINT=

# Host ports. Change only when a default port is already occupied.
AUTH_PORT=8001
AI_ASSISTANT_PORT=8002
CONTENT_PORT=8003
CLASSROOM_PORT=8004
ASSIGNMENTS_PORT=8005
ANSWERS_PORT=8006
COLLABORATION_PORT=8007
ANALYTICS_PORT=8010
FRONTEND_PORT=8080

POSTGRES_PORT=5432
REDIS_PORT=6380
