# HTTP port the app listens on. Overridden by the hosting platform in production.
PORT=8000

DATABASE_URL=postgresql+asyncpg://classroom:classroom@db:5432/classroom
REDIS_URL=redis://redis:6379/0

# Auth Service's public key, used to verify RS256 JWTs locally (no network
# call to Auth Service per request). In production this is fetched once at
# startup from Auth Service's /auth/public-key and cached to this path.
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ISSUER=auth-service
INTERNAL_SERVICE_TOKEN=dev-insecure-service-token
ALLOW_LEGACY_INTERNAL_SERVICE_TOKEN=true
EVENT_BUS_REDIS_URL=redis://redis:6379/0
EVENT_BUS_ENABLED=true
RATE_LIMIT_REDIS_URL=redis://redis:6379/0
OTEL_EXPORTER_OTLP_ENDPOINT=

JOIN_PASSWORD_MIN_LENGTH=8
JOIN_ATTEMPTS_PER_IP_LIMIT=15
JOIN_ATTEMPTS_PER_IP_WINDOW_SECONDS=3600
JOIN_ATTEMPTS_GLOBAL_PER_CLASSROOM_LIMIT=50
JOIN_ATTEMPTS_GLOBAL_PER_CLASSROOM_WINDOW_SECONDS=3600
JOIN_LOCKOUT_SECONDS=900

WS_HEARTBEAT_INTERVAL_SECONDS=25
WS_HEARTBEAT_MISSED_LIMIT=3

LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_WS_URL=ws://localhost:7880
LIVEKIT_TOKEN_TTL_SECONDS=3600

WHITEBOARD_JWT_SECRET=dev-insecure-change-me
WHITEBOARD_BASE_URL=http://localhost:9000
WHITEBOARD_SERVICE_API_KEY=
