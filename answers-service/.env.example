# HTTP port the app listens on. Overridden by the hosting platform in production.
PORT=8000

DATABASE_URL=postgresql+asyncpg://answers:answers@db:5432/answers
REDIS_URL=redis://redis:6379/0

JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ISSUER=auth-service

STORAGE_ROOT=storage

CONTENT_SERVICE_BASE_URL=http://localhost:8003
CONTENT_SERVICE_TOKEN=dev-insecure-service-token
AUTH_SERVICE_BASE_URL=http://localhost:8001
SERVICE_CLIENT_ID=answers-service
SERVICE_CLIENT_SECRET=
EVENT_BUS_REDIS_URL=redis://redis:6379/0
EVENT_BUS_ENABLED=true
ANSWER_SUBMIT_RATE_LIMIT=120
ANSWER_SUBMIT_WINDOW_SECONDS=60
OTEL_EXPORTER_OTLP_ENDPOINT=

STUDENT_ANSWER_LIMIT_BYTES=15728640
ALLOW_LEGACY_INTERNAL_SERVICE_TOKEN=true
