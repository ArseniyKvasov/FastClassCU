# HTTP port the app listens on. Overridden by the hosting platform in production.
PORT=8000

DATABASE_URL=postgresql+asyncpg://auth:auth@db:5432/auth

JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ISSUER=auth-service
ACCESS_TOKEN_TTL_SECONDS=900
GUEST_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=2592000

PROVIDERS_CONFIG_PATH=providers.yaml

# Base URL this service is reachable at, used to build OAuth redirect_uri
PUBLIC_BASE_URL=http://localhost:8001

# Change this in every real deployment - signs the OAuth "state" param.
OAUTH_STATE_SECRET=dev-insecure-change-me

SERVICE_ACCESS_TOKEN_TTL_SECONDS=300
SERVICE_CLIENTS_CONFIG_PATH=service_clients.yaml
EVENT_BUS_REDIS_URL=redis://redis:6379/0
EVENT_BUS_ENABLED=true
RATE_LIMIT_REDIS_URL=redis://redis:6379/0
OAUTH_CALLBACK_RATE_LIMIT=30
OAUTH_CALLBACK_WINDOW_SECONDS=60
OTEL_EXPORTER_OTLP_ENDPOINT=

# Referenced by providers.yaml via ${VAR} substitution - fill in per business/deployment.
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
VK_CLIENT_ID=
VK_CLIENT_SECRET=

# Referenced by service_clients.yaml via ${VAR} substitution.
ANSWERS_SERVICE_CLIENT_SECRET=
AI_ASSISTANT_SERVICE_CLIENT_SECRET=
COLLABORATION_SERVICE_CLIENT_SECRET=
