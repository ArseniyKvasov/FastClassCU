{
  "title": "FastClass Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "HTTP RPS",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(fastclass_http_requests_total[5m])) by (service)"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP p95 Latency",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(fastclass_http_request_duration_seconds_bucket[5m])) by (le, service))"
        }
      ]
    },
    {
      "id": 3,
      "title": "Outbox Backlog",
      "type": "timeseries",
      "targets": [
        {
          "expr": "fastclass_outbox_backlog"
        }
      ]
    },
    {
      "id": 4,
      "title": "Consumed Events",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(fastclass_events_consumed_total[5m])) by (consumer, status)"
        }
      ]
    },
    {
      "id": 5,
      "title": "Rate Limit Blocks",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(fastclass_rate_limit_block_total[5m])) by (service, limiter)"
        }
      ]
    }
  ]
}
